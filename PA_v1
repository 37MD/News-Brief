<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy"
        content="default-src 'self';
                 script-src  'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net;
                 style-src   'unsafe-inline' https://fonts.googleapis.com;
                 font-src    https://fonts.gstatic.com;
                 img-src     * data:;
                 connect-src *;">
  <title>PDF Assistant</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>

  <style>
    /* ════════════════════════════════════════════════════════════════════
       CSS §1 — ORIGINAL PULSE DESIGN TOKENS
    ════════════════════════════════════════════════════════════════════ */
    :root {
      --ink:            #1a1a18;
      --paper:          #f5f0e8;
      --accent:         #1a5c3a;
      --rule:           #c8c0b0;
      --muted:          #5a554c;
      --meta-color:     #8c867a;
      --error:          #c0392b;
      --success:        #2e7d52;
      --reader-font-sz: 17px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background:  var(--paper);
      color:       var(--ink);
      font-family: 'IBM Plex Sans', sans-serif;
      min-height:  100vh;
      line-height: 1.6;
    }

    /* ════════════════════════════════════════════════════════════════════
       CSS §2 — CONTROLS BAR
    ════════════════════════════════════════════════════════════════════ */
    .controls-bar {
      position:    absolute;
      top:         16px;
      right:       20px;
      z-index:     100;
      display:     flex;
      align-items: center;
      gap:         10px;
    }
    .btn-outline {
      font-family:    'IBM Plex Mono', monospace;
      font-size:      13px;
      background:     transparent;
      color:          var(--accent);
      border:         1px solid var(--accent);
      padding:        6px 12px;
      border-radius:  4px;
      cursor:         pointer;
      font-weight:    500;
      transition:     0.2s;
      white-space:    nowrap;
      text-transform: uppercase;
    }
    .btn-outline:hover { background: var(--accent); color: var(--paper); }
    #doc-upload-input { display: none; }

    /* ════════════════════════════════════════════════════════════════════
       CSS §3 — MASTHEAD
    ════════════════════════════════════════════════════════════════════ */
    .masthead {
      border-bottom: 3px double var(--ink);
      padding:       40px 20px;
      text-align:    center;
      background:    var(--paper);
      position:      relative;
    }
    .masthead-title {
      font-family: 'Playfair Display', serif;
      font-size:   clamp(32px, 5vw, 56px);
      font-weight: 700;
    }
    .tagline {
      font-family:    'IBM Plex Mono', monospace;
      font-size:      10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color:          var(--meta-color);
      margin-top:     8px;
    }

    /* ════════════════════════════════════════════════════════════════════
       CSS §4 — FEED CONTAINER & ARTICLE CARDS
    ════════════════════════════════════════════════════════════════════ */
    .container {
      max-width: 800px;
      margin:    0 auto;
      padding:   20px 20px 100px;
    }
    .feed-item {
      margin-bottom:  40px;
      border-bottom:  1px solid var(--rule);
      padding-bottom: 30px;
      animation:      fadeIn 0.4s ease forwards;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    .headline {
      font-family:     'Playfair Display', serif;
      font-size:       24px;
      color:           var(--ink);
      font-weight:     700;
      margin-bottom:   10px;
      cursor:          pointer;
      line-height:     1.2;
    }
    .headline:hover { color: var(--accent); text-decoration: underline; }
    .description {
      font-size:     15px;
      color:         var(--muted);
      margin-bottom: 12px;
      line-height:   1.6;
    }
    .meta {
      font-family:    'IBM Plex Mono', monospace;
      font-size:      10px;
      color:          var(--meta-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ════════════════════════════════════════════════════════════════════
       CSS §5 — READER MODE & AI PANEL
    ════════════════════════════════════════════════════════════════════ */
    #reader-backdrop { display: none; position: fixed; inset: 0; background: rgba(26,26,24,0.45); z-index: 998; backdrop-filter: blur(2px); }
    #reader-backdrop.open { display: block; }
    #reader-panel {
      position: fixed; top: 0; right: 0; bottom: 0; width: 100%; max-width: 780px;
      background: var(--paper); z-index: 999; display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.35s cubic-bezier(.4,0,.2,1);
      box-shadow: -4px 0 40px rgba(0,0,0,0.18);
    }
    #reader-panel.open { transform: translateX(0); }
    .reader-topbar { display: flex; align-items: center; gap: 10px; padding: 14px 20px; border-bottom: 1px solid var(--rule); }
    .reader-scroll { overflow-y: auto; flex: 1; padding: 40px 60px; }
    .reader-article-title { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; margin-bottom: 20px; }
    .reader-body { font-size: var(--reader-font-sz); white-space: pre-wrap; line-height: 1.8; color: var(--ink); }

    #ai-panel {
      position: absolute; top: 65px; right: 20px; width: 380px; max-width: calc(100vw - 40px);
      background: #fff; border: 1px solid var(--rule); border-radius: 12px;
      display: flex; flex-direction: column; opacity: 0; pointer-events: none;
      transform: translateY(-10px); transition: all 0.3s ease; z-index: 1005;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15); max-height: 70vh;
    }
    #ai-panel.open { opacity: 1; pointer-events: auto; transform: translateY(0); }
    .ai-header { padding: 12px 16px; border-bottom: 1px solid var(--rule); font-family: 'IBM Plex Mono', monospace; font-size: 11px; font-weight: bold; color: var(--accent); display: flex; justify-content: space-between; }
    .ai-chat-area { flex: 1; overflow-y: auto; padding: 20px; font-size: 14px; display: flex; flex-direction: column; gap: 12px; }
    .ai-input-wrapper { padding: 15px; border-top: 1px solid var(--rule); display: flex; gap: 8px; }
    .ai-input { flex: 1; border: 1px solid var(--rule); padding: 10px; border-radius: 6px; outline: none; }
    
    .msg { padding: 10px 14px; border-radius: 8px; max-width: 85%; }
    .msg.user { background: #eee; align-self: flex-end; color: #333; }
    .msg.bot { background: var(--accent); color: white; align-self: flex-start; }

    .loader {
        position: fixed; inset: 0; background: rgba(245, 240, 232, 0.95);
        display: none; flex-direction: column; align-items: center; justify-content: center;
        z-index: 10000; font-family: 'IBM Plex Mono', monospace;
    }
    .system-msg { text-align: center; color: var(--meta-color); margin-top: 100px; font-family: 'IBM Plex Mono', monospace; font-size: 12px; }
  </style>
</head>
<body>

  <div class="loader" id="loader">
    <div style="font-size: 30px; margin-bottom: 15px;">🔍</div>
    <div id="loader-text">Parsing Document...</div>
  </div>

  <div class="controls-bar">
    <button class="btn-outline" onclick="document.getElementById('doc-upload-input').click()">+ Upload PDF/EPUB</button>
    <input type="file" id="doc-upload-input" accept=".pdf,.epub">
    <button class="btn-outline" id="clear-api-key" style="color:var(--muted); border-color:var(--rule)">API Key</button>
  </div>

  <header class="masthead">
    <h1 class="masthead-title">PDF Assistant</h1>
    <div class="tagline">Financial Auditor & Intelligent Reader</div>
  </header>

  <div class="container" id="feed-container">
    <div class="system-msg">READY FOR ANALYSIS. UPLOAD A DOCUMENT TO START.</div>
  </div>

  <div id="reader-backdrop"></div>
  <div id="reader-panel">
    <div class="reader-topbar">
      <button class="btn-outline" onclick="closeReader()">← Back</button>
      <div style="flex:1"></div>
      <button class="btn-outline" id="ai-toggle" style="background: rgba(26, 92, 58, 0.05);">Ask Gemini</button>
    </div>
    <div class="reader-scroll">
      <h1 class="reader-article-title" id="r-title"></h1>
      <div class="reader-body" id="r-body"></div>
    </div>
    
    <div id="ai-panel">
      <div class="ai-header">
        <span>GEMINI ANALYST</span>
        <span style="cursor:pointer" onclick="resetChat()">RESET CHAT</span>
      </div>
      <div class="ai-chat-area" id="ai-chat">
        <div class="msg bot">I have processed this section. What technical or financial insights do you need?</div>
      </div>
      <div class="ai-input-wrapper">
        <input type="text" class="ai-input" id="ai-input" placeholder="Ask anything...">
        <button class="btn-outline" onclick="sendChat()" style="background:var(--accent); color:white; border:none;">Ask</button>
      </div>
    </div>
  </div>

  <script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    const STATE = {
        items: [],
        activeIdx: -1,
        key: localStorage.getItem('GEMINI_KEY') || ''
    };

    const DOM = {
        feed: document.getElementById('feed-container'),
        loader: document.getElementById('loader'),
        lText: document.getElementById('loader-text'),
        input: document.getElementById('doc-upload-input'),
        reader: document.getElementById('reader-panel'),
        backdrop: document.getElementById('reader-backdrop'),
        rTitle: document.getElementById('r-title'),
        rBody: document.getElementById('r-body'),
        aiPanel: document.getElementById('ai-panel'),
        aiChat: document.getElementById('ai-chat'),
        aiInput: document.getElementById('ai-input')
    };

    // --- API KEY MGMT ---
    document.getElementById('clear-api-key').onclick = () => {
        const k = prompt("Enter Gemini API Key:", STATE.key);
        if (k) { STATE.key = k; localStorage.setItem('GEMINI_KEY', k); }
    };

    // --- DOCUMENT PROCESSING ---
    DOM.input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        STATE.items = [];
        DOM.feed.innerHTML = '';
        DOM.loader.style.display = 'flex';
        DOM.lText.textContent = "Extracting raw text...";

        try {
            let fullText = "";
            if (file.name.endsWith('.pdf')) {
                fullText = await extractPdfText(file);
            } else {
                fullText = await extractEpubText(file);
            }

            DOM.lText.textContent = "Identifying articles & chapters...";
            const segments = splitIntoArticles(fullText);

            for (let i = 0; i < segments.length; i++) {
                DOM.lText.textContent = `Summarizing item ${i+1} of ${segments.length}...`;
                const summary = await getAiSummary(segments[i].content);
                const item = { ...segments[i], summary, history: [] };
                STATE.items.push(item);
                addFeedCard(item, i);
            }
        } catch (err) {
            console.error(err);
            alert("Analysis failed: " + err.message);
        } finally {
            DOM.loader.style.display = 'none';
            e.target.value = '';
        }
    };

    async function extractPdfText(file) {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        let text = "";
        for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const content = await page.getTextContent();
            text += content.items.map(item => item.str).join(" ") + "\n\n";
        }
        return text;
    }

    async function extractEpubText(file) {
        const zip = await JSZip.loadAsync(file);
        let text = "";
        for (const f in zip.files) {
            if (f.match(/\.(html|xhtml)$/)) {
                const html = await zip.files[f].async("string");
                const doc = new DOMParser().parseFromString(html, "text/html");
                text += doc.body.innerText + "\n\n";
            }
        }
        return text;
    }

    function splitIntoArticles(text) {
        // Sophisticated split for editorials or book chapters
        const sections = [];
        const lines = text.split('\n');
        let currentTitle = "Introduction / Overview";
        let currentBody = "";

        // Heuristic: Looking for short lines that look like titles or specific news markers
        // Also captures markers like "THE HINDU", "INDIAN EXPRESS", "Chapter 1", etc.
        const titleRegex = /^(Editorial|Chapter|Article|Section|Part)\s+\d+|[A-Z\s]{5,60}$/;

        lines.forEach(line => {
            const trimmed = line.trim();
            if (titleRegex.test(trimmed) && currentBody.trim().length > 300) {
                sections.push({ title: currentTitle, content: currentBody.trim() });
                currentTitle = trimmed;
                currentBody = "";
            } else {
                currentBody += line + "\n";
            }
        });
        
        sections.push({ title: currentTitle, content: currentBody.trim() });
        return sections;
    }

    // --- AI COMMUNICATION ---
    async function getAiSummary(content) {
        if (!STATE.key) return content.slice(0, 490) + "...";
        const prompt = `Summarize this text in exactly 500 characters or less. Focus on the core message and key technical or financial facts. Text:\n\n${content.slice(0, 8000)}`;
        return callGemini([{ role: "user", parts: [{ text: prompt }] }]);
    }

    async function callGemini(contents) {
        const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${STATE.key}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ 
                contents,
                system_instruction: { 
                    parts: [{ text: "You are a professional Financial Auditor and Technical Market Analyst. Provide deep, evidence-based answers. Use concepts like 'Positive/Negative Consolidation' when relevant. No hedging or standard AI disclaimers; answer as a technical expert." }] 
                }
            })
        });
        const data = await res.json();
        if (data.error) throw new Error(data.error.message);
        return data.candidates[0].content.parts[0].text;
    }

    // --- UI HELPERS ---
    function addFeedCard(item, idx) {
        const div = document.createElement('div');
        div.className = 'feed-item';
        div.innerHTML = `
            <div class="headline" onclick="openReader(${idx})">${item.title}</div>
            <div class="description">${item.summary}</div>
            <div class="meta">Analysis Complete • Full Article Ready</div>
        `;
        DOM.feed.appendChild(div);
    }

    window.openReader = (idx) => {
        STATE.activeIdx = idx;
        const it = STATE.items[idx];
        DOM.rTitle.textContent = it.title;
        DOM.rBody.textContent = it.content;
        DOM.reader.classList.add('open');
        DOM.backdrop.classList.add('open');
        renderChat();
    };

    window.closeReader = () => {
        DOM.reader.classList.remove('open');
        DOM.backdrop.classList.remove('open');
        DOM.aiPanel.classList.remove('open');
    };

    document.getElementById('ai-toggle').onclick = () => DOM.aiPanel.classList.toggle('open');

    window.sendChat = async () => {
        const q = DOM.aiInput.value.trim();
        if (!q) return;
        const it = STATE.items[STATE.activeIdx];
        
        const contextMsg = `Reference this article for your audit:\n\n${it.content.slice(0, 30000)}\n\nQuestion: ${q}`;
        it.history.push({ role: "user", parts: [{ text: contextMsg }] });
        
        DOM.aiInput.value = "";
        renderChat();

        try {
            const ans = await callGemini(it.history);
            it.history.push({ role: "model", parts: [{ text: ans }] });
            renderChat();
        } catch (e) { alert(e.message); }
    };

    function renderChat() {
        DOM.aiChat.innerHTML = '';
        const it = STATE.items[STATE.activeIdx];
        it.history.forEach(m => {
            const div = document.createElement('div');
            div.className = `msg ${m.role === 'user' ? 'user' : 'bot'}`;
            let txt = m.parts[0].text;
            if (txt.includes('Question:')) txt = txt.split('Question:').pop();
            div.textContent = txt;
            DOM.aiChat.appendChild(div);
        });
        DOM.aiChat.scrollTop = DOM.aiChat.scrollHeight;
    }

    window.resetChat = () => {
        if (STATE.activeIdx !== -1) {
            STATE.items[STATE.activeIdx].history = [];
            renderChat();
        }
    };

    DOM.aiInput.onkeydown = (e) => { if (e.key === 'Enter') sendChat(); };
  </script>
</body>
</html>
